NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: extra browser origins allowed to make state-changing API requests
# (comma-separated, e.g. behind a reverse proxy). The app's own origin is always
# allowed. Used by the CSRF/Origin check.
EXTRA_ALLOWED_ORIGINS=

# Optional: structured log level (debug | info | warn | error). Default: info.
LOG_LEVEL=info

# Optional: error tracking. Opt-in — leave BOTH blank to disable (the default;
# no network egress). Set one to forward server-side errors to your sink. See
# docs/OBSERVABILITY.md.
SENTRY_DSN=
ERROR_TRACKING_DSN=

# BYO provider credentials (ADR-0010). 32-byte key (64-hex or base64) used to encrypt
# user-supplied API keys before storage. MUST match the bridge's CREDENTIAL_ENCRYPTION_KEY.
# Server-only — never exposed to the browser. Generate: `openssl rand -hex 32`.
CREDENTIAL_ENCRYPTION_KEY=
