# ── docker compose environment ────────────────────────────────────────────────
# Copy to `.env` (gitignored) and fill in:  cp .env.docker.example .env
# Used by docker-compose.yml. See docs/SELF_HOSTING.md for the full guide.

# Browser-reachable Supabase URL (baked into the web bundle at build time).
#   • Production: your real Supabase URL, e.g. https://<project-ref>.supabase.co
#   • Local `supabase start`: http://localhost:54321
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (anon) key — the value labelled "publishable" / sb_publishable_… by
# `supabase status` or your project's API settings. NEVER the service_role key.
# (Naming rule: PUBLISHABLE_KEY, never the deprecated *_ANON_KEY.)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Service-role key — FULL database privileges. Server + bridge only; never exposed
# to the browser. Treat as a secret; inject via your secret manager in production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL the app is served from (used for redirects / absolute links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL — only when the containers must reach Supabase at a DIFFERENT address
# than the browser does. Leave UNSET for a production Supabase (same URL works for
# both). For a local `supabase start` on the host, set:
#   SERVER_SUPABASE_URL=http://host.docker.internal:54321
# SERVER_SUPABASE_URL=

# OPTIONAL — extra browser origins allowed for cross-origin POST (CSRF allowlist),
# comma-separated. Usually empty.
# EXTRA_ALLOWED_ORIGINS=

# OPTIONAL — host port to publish the web app on (container always listens on 3000).
# WEB_PORT=3000

# OPTIONAL — bridge tuning (defaults shown; safe to omit).
# BRIDGE_WORKER_ID=bridge-compose-1
# BRIDGE_POLL_INTERVAL_MS=2000
# BRIDGE_MAX_CONCURRENT_RUNS=3
# BRIDGE_HEARTBEAT_INTERVAL_MS=5000
# BRIDGE_STALE_RUN_TIMEOUT_MS=60000
