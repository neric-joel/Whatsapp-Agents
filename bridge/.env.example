# AgentRoom bridge — all env is OPTIONAL with safe defaults. The bridge reads/writes
# the local SQLite DB (@agentroom/db); there is no Supabase. Copy to .env to override.

# Where local app-data lives (must match the web app). Defaults to
# %APPDATA%\AgentRoom on Windows, otherwise ~/.agentroom.
AGENTROOM_HOME=
BRIDGE_WORKER_ID=bridge-local-1
BRIDGE_POLL_INTERVAL_MS=2000
BRIDGE_MAX_CONCURRENT_RUNS=3
BRIDGE_HEARTBEAT_INTERVAL_MS=5000
BRIDGE_STALE_RUN_TIMEOUT_MS=60000
# Liveness + metrics HTTP server port (GET /healthz, GET /metrics). 0 disables it.
# Bind to localhost / an internal network only — these endpoints are unauthenticated.
BRIDGE_HEALTH_PORT=9090
# Structured log level (debug | info | warn | error). Default: info.
LOG_LEVEL=info
# Optional error tracking. Opt-in — leave BOTH blank to disable (no network egress).
# See docs/OBSERVABILITY.md.
SENTRY_DSN=
ERROR_TRACKING_DSN=
# Paths to CLI binaries (override if not on PATH)
CLAUDE_BIN=claude
CODEX_BIN=codex
# Optional: third-party image text/OCR extraction (DATA EGRESS to OpenAI).
# OFF by default. To enable, set the flag to true AND provide an API key.
# When enabled, uploaded image bytes are sent to OpenAI's API.
ENABLE_IMAGE_TEXT_EXTRACTION=false
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional: extra env var names (comma-separated) to forward to agent CLI
# subprocesses. Secrets (*_TOKEN, *_SECRET, *_KEY, BRIDGE_*) are NEVER forwarded.
BRIDGE_CHILD_ENV_ALLOW=

# BYO provider credentials (ADR-0010). 32-byte key (64-hex or base64) used to decrypt
# user-stored API keys at spawn. Server-only — never the browser, never logged.
# Generate: `openssl rand -hex 32`. Leave blank to disable the BYO-credential feature.
CREDENTIAL_ENCRYPTION_KEY=
